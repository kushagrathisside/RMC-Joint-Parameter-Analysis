# .gitignore - repository root
# Purpose: keep Python artifacts, virtualenvs, IDE files, logs and large result files out of the repo so
# the repository is safe to publish and small to clone.

## Python
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
eggs/
parts/
sdist/
pip-wheel-metadata/
*.egg

# Installer logs
install.log

## Virtual environments
.venv/
venv/
env/
ENV/
venv*/

## IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

## OS files
.DS_Store
Thumbs.db

## Jupyter
.ipynb_checkpoints/

## Testing / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml

## Type checkers / caches
.mypy_cache/
.pyre/
.ruff_cache/

## Logs and runtime files
*.log
logs/
MUJOCO_LOG.TXT

## Project outputs / large files
results/
*.npz
visualizer_recording_*.npz

## Misc
*.swp
*.swo
*.bak
*.tmp

# Secrets / environment
.env
.env.*
.pytest_cache
.venv
venv
__pycache__
*.pyc
.codex
